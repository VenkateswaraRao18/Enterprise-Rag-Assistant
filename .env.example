# ── Provider ─────────────────────────────────────────────
# local dev: ollama | AWS production: gemini
LLM_PROVIDER=ollama

# ── Ollama (local) ───────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=gemma3:4b

# ── Gemini (production) ───────────────────────────────────
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# ── Qdrant ───────────────────────────────────────────────
# Local: docker run -p 6333:6333 qdrant/qdrant
# AWS:  http://qdrant.techcorp.local:6333 (Cloud Map, private)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=techcorp_docs

# ── API server ───────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional: require X-API-Key on POST /api/ask (recommended for public ALB)
API_KEY=

# ── Indexing ─────────────────────────────────────────────
EMBED_BATCH_SIZE=16
QDRANT_UPSERT_BATCH_SIZE=64
